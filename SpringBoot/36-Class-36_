package com.form.Controller;

import java.util.ArrayList;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;

import com.form.Repo.StudentRepository;
import com.form.binding.Student;

@Controller
public class StudentController {
	
	@Autowired
	private StudentRepository repo;

	
	//method to load student form 
	@GetMapping("/")
	public String loadForm(Model model) {
		
		loadFormData(model);
		
		return"index";		
		
	}

	private void loadFormData(Model model) {
		List<String> coursesList = new ArrayList<>();
		coursesList.add("Java");
		coursesList.add("Generative AI");
		coursesList.add("React");
		coursesList.add("AWS Cloud");
		coursesList.add("Devops");
		coursesList.add("Python");
		
		List<String> timingsList = new ArrayList<>();
		
		timingsList.add("Morning");
		timingsList.add("Afternoon");
		timingsList.add("Evening");
		
		Student student = new Student();
		//model is used to send the data in key-value format , so here keys are " courses and timings" and the values are "timingsList, coursesList"
		model.addAttribute("courses", coursesList);
		model.addAttribute("timings", timingsList);
		model.addAttribute("student", student);
	}
	
	//method to save student from data 
	/*
			in index.jsp page we have mentiond "<form:form action="save" modelAttribute="student" method="POST">"
            POST request to save the data, so we need to create a post method to save the data 
    */
	@PostMapping("/save")
		public String handleSubmit(Student s, Model model) {
			System.out.println(s);
			//logic to save data
			
			model.addAttribute("msg", "Registered successfully");
			loadFormData(model);
			return "index";
		}
		
	//method to display saved students data 
	
		
	}
