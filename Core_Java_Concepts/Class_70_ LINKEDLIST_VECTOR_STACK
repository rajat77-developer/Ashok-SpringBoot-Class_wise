package Collections;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.ListIterator;

public class ListArrayListDemo {

	
	public static void main(String[] args) {
		
		List l = new ArrayList();
		l.add(100);
		l.add(100);
		l.add(200);
		l.add(300);
		l.add(400);
		l.add(100);
		l.add(1000);
		l.add(null);
		
	//	Approach : 1 --> to get the data from ArrayList
		System.out.println("===========First Approach============");
		System.out.println("===========By using For Loop Approach============");
		
		for(int i =0; i< l.size();i++) {
			
			System.out.println(l.get(i));
		}
		
		System.out.println("============Second Approach==========");
		System.out.println("===========For Each Loop Approach============");
	// Approach : 2 --> to get the data from ArrayList
		
		for(Object obj : l) {
			
			System.out.println(obj);
		}
		
	// Approach : 3 --> to get the data from ArrayList
		
		System.out.println("===========Third Apparoach============");
		System.out.println("===========Iterator Apparoach============");
		
		Iterator iterator = l.iterator();

		while(iterator.hasNext()){
			System.out.println(iterator.next());
			
		}
		
		//Approach :4 --> to get the data from ArrayList
		
		System.out.println("===========Fourth Approach============");
		System.out.println("===========ListIterator Apparoach============");
		
		ListIterator listIterator = l.listIterator();
		
		while(listIterator.hasNext()) {
			
			System.out.println(listIterator.next());
		}
		
		System.out.println("===========Fifthth Approach============");
		System.out.println("===========For-each()method ::Lambda Approach============");
		
		
		
		l.forEach(i -> {
			
			System.out.println(i);
		});
		
	}
}


