package com.ibm.aadhar;

public class variableArguments {
	
	public void add (int... a) {
		
		int sum = 0;
		
		for(int x : a) {
			
			sum = sum + x;
		}
		System.out.println(sum);
		
	}

	public static void main(String[] args) {
		
		
		variableArguments v = new variableArguments();
		
		v.add(20, 30);
		v.add(10, 20, 30);
		v.add(20, 50, 40, 60);
		v.add(11, 22, 33, 44, 55, 66);
		
	}	
	
}

                                                  
