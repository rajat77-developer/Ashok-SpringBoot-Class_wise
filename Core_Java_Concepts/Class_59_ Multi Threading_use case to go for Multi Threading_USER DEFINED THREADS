NOTE: Thread is a predefiend class available in java.lang package. In Thread class, we have a static method currentThread().


                                    =================================
                                        USER DEFINED THREADS
                                    =================================

->In java, we can create Threads in 2 ways.
        1. By extending Thread class
        
        2. By implementing runnable interface
---> Java program to create user defined thread using Thread class.


package p1;

public class Demo1 extends Thread {
	
	public void run() {
		
		System.out.println("my thread started....");
		m1();
		System.out.println("my thread completed .........");
	}
	
	
	public void m1() {
		
		
		System.out.println("i am from m1() method ");
	}
	
	
	public static void main(String[] args) {
		
		Thread currentThread = Thread.currentThread();
		String name = currentThread.getName();
		
		System.out.println("thread name is :" + name);
		
		
		
		Demo1 d = new Demo1();
		
		Thread t = new Thread(d);
		
		t.start();//--> internally it will call the run() method 
		
		
		System.out.println(name + "thread completed ");
		
	}

}









