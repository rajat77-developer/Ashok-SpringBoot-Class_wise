Task: calling instance variable in constuructor by using this keyword.

--> "this" keyword is represent 
--> this is a predefiend keyword in java
-->it is used to represent current class object

package ConstructorConcept;

public class ConstructorBasic {

	String name;
	float salary;

	ConstructorBasic(String name, float salary) {

		this.name = name;
		this.salary = salary;

		System.out.println(name + "  " + salary); // this will print local variable
    System.out.println(this.name + "  " + this.salary);//this will print instance variable by using "this" keyword
	}

	public static void main(String[] args) {
		ConstructorBasic b = new ConstructorBasic("raja", 10452.00f);
		ConstructorBasic c = new ConstructorBasic("moja", 5486.25f);
		ConstructorBasic d = new ConstructorBasic("monu", 7485.60f);
	}

}

                      =========================
                       CONSTRUCTOR OVERLOADING
                      =========================


--> Writing more than one constructor with different parameters is called as constructor overloading.




Example--->

package ConstructorConcept;
public class ConstructorBasic {

	String name;
	float salary;
	ConstructorBasic(){
		    	}
	
	ConstructorBasic(String name, float salary) {

		this.name = name;
		this.salary = salary;
    System.out.println(name + "  " + salary);
	}
	
	ConstructorBasic(String name){
		
		this.name=name;
		System.out.println(this.name+"-"+this.salary);
	}

	public static void main(String[] args) {
		
		// these 3 objects are calling constructor 1
		
		ConstructorBasic b = new ConstructorBasic("raja", 10452.00f);
		ConstructorBasic c = new ConstructorBasic("moja", 5486.25f);
		ConstructorBasic d = new ConstructorBasic("monu", 7485.60f);
		
		//this is calling constructor 2
		ConstructorBasic e = new ConstructorBasic("monu");
		
		//this is going to call default constructor because of zero parameter.
		
		ConstructorBasic f = new ConstructorBasic(); //no output
        }  
	}































