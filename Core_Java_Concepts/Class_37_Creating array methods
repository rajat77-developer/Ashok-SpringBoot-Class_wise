package MethodConcept;

public class Person {
	
	int id;
	String name;
	
	Person[] m1(){
		
		Person p1= new Person();
		p1.id=1;
		p1.name="Raju";
		
		Person p2 = new Person();
		p2.id=2;
		p2.name="Rani";
		
		Person p3 = new Person();
		p3.id=3;
		p3.name="Ranjit";
		
		Person[]arr = {p1,p2,p3};
		
		return arr;
		
	}
	public static void main(String[] args) {
		
		
		
		Person d = new Person(); // Here we have created one object to call the method 
		Person [] arr = d.m1(); //we call the method and store into an array
		
		//we use for each loop to print the array (first approach)
		for(Person person: arr) {
			
			System.out.println(person.id+"--"+person.name);
		}
		
		System.out.println("  ");
		
		
		//we use "for" loop to call the array index to print the data (second approach )
		for (int i =0; i<arr.length;i++) {
			
			System.out.println(arr[i].id+"--"+arr[i].name);
		}
	}

}


