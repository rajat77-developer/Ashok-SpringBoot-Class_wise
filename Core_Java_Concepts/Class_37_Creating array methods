
Q. write a java program to return a university data based on university ID.
 101-->id-101,name->oxford
 102-->id-102,name->standford

Answer---> 


package MethodConcept;

/*write a java program to return a university data based on university ID.
101-->id-101,name->oxford
102-->id-102,name->standford
*/
public class University {

	
	
	int id;
	String name;
	
	public static void main(String[] args) {
		
		University n = new University();
		University university=n.m1(102);
		
		System.out.println(university.id+"-->"+university.name);
		
	}
	
	University m1(int id) {
		
		University u = new University();
		
		if(id==101) {
			
			u.id=101;
			u.name="oxford";
			
		}else if(id==102){
			
			u.id=102;
			u.name="standford";
			
		}
		return u;	
	}
	
}

