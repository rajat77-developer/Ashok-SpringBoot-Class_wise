comparable example
------------------

Student.java
------------
package Collections;

public class Student implements Comparable<Student>{
	 
	int id;
	String name;
	int rank;
	
	
	//parameterized constructor is used to initialize instance variable of the class
	public Student(int id, String name, int rank) {

	   this.id=id;
	   this.name=name;
	   this.rank=rank;
	}

	@Override
	public int compareTo(Student s) {
		//return this.id - s.id;
		//return this.name.compareTo(s.name);
		return this.rank - s.rank;
	
	}
	
	
	@Override
	//to print object data we will use toString()
	public String toString() {
		return "Student [id=" + id + ", name=" + name + ", rank=" + rank + "]";
	}


}


