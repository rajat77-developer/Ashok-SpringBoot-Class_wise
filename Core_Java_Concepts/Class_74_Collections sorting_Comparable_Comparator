package Collections;

import java.util.ArrayList;
import java.util.Collections;
import java.util.Comparator;

public class EmpDemo {
	
	public static void main(String[] args) {
		
		ArrayList<Employee> al = new ArrayList<>();
		
		al.add(new Employee(101, "David", 15000.000));
		al.add(new Employee(105, "Putin", 25000.000));
		al.add(new Employee(103, "Cathy", 45000.000));
		al.add(new Employee(104, "Annya",  35000.000));

	
		//Collections.sort(al, new EmpIdComparator());
		//Collections.sort(al, new EmpNameComparator());
		
		
		
		//we can also create anonymous sorting order to sort array like below methods
		
		//this is one is by id (custom sorting)
		Collections.sort(al, new Comparator<Employee>() {

			@Override
			public int compare(Employee e1, Employee e2) {
				return e1.id -e2.id;
			}		
			
		});
		
		//this one is by name (custom sorting)
		
		Collections.sort(al,  new Comparator<Employee>() {

			@Override
			public int compare(Employee e1, Employee e2) {
				return e1.name.compareTo(e2.name);
				
			}
			
		});
		
		
		//this is natural sorting order
		
		Collections.sort(al, new Comparator<Employee>() {

			@Override
			public int compare(Employee e1, Employee e2) {

			if(e1.id > e2.id) {
				
				return -1;
			}else if(e1.id < e2.id){
				
				return 1;
			}else {
				
				return 0;
			}
			
			
			
			}
			
			
			
		});
		
		for(Employee e : al ) {
		
		System.out.println(e);
		 
	}
  }
}

