 package MethodConcept;

//take product class with productId, productName, productPrice as properties
//Create Driver class with print() method to print product data

 public class Driver {
	
	public static void main(String[] args) {
		
		Product p = new Product();
		p.productId=1;
		p.productName="soap";
		p.productPrice=65.25;
		
		Driver d =new Driver();
		d.print(p);
			
	}

//void print(Product p) --> (meaning) --> taking object input inside the method to print the product data  "(Product p)"

	void print(Product p) {
		
		System.out.println(p.productId + "-->"+p.productName+ "-->"+ p.productPrice);
	}
}

class Product{
	
	
	int productId;
	String productName; 
	double productPrice;
}
