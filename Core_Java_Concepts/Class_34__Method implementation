package MethodConcept;

import java.util.Arrays;

public class Driver {
	
	public static void main(String[] args) {
		
		
		//create an array and pass arrays values while calling the method
		int[] arr= {10,20,30,40,50};
		Driver.print(arr);
		
		//we can also call static method without using class name because this methods belongs to same class 
		
		print(arr);
		
	}	
	static void print (int[]arr) {
		
		String str=Arrays.toString(arr);
		System.out.println(str);
	}
	
}

