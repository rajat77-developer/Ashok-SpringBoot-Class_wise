          SUPER keyword

--> It is used to refer parent class properties .

===============================================================================================

Program to understand full flow of program:::

package Inheritance;


class Parent{
	
	void m1() {
		
		System.out.println("Parent Class::M1 - called");
	}
void m2() {
		
		
		System.out.println("Parent class :: m2 called by super keyword");
	}
}
class Child extends Parent{
	
	void m2() {
		
		
		System.out.println("Child class :: m2 called");
		super.m2();
	}
}

public class ParentChildConcept {

	
	public static void main(String[] args) {
		Child c = new Child();
		c.m1();
		c.m2();
		int c1 =c.hashCode();
		System.out.println("Hash code value is :: "+c1);
	}
}


