Q-1) Write a Java program to count the total number of occurrences of a given character in a string

String s = "java"

Char = 'a'

Output : 2



class CharOcc {

    public static void main (String[ ] args){

        String s = "java";
        char ch = 'a';

        char arr[ ] = s.toCharArray ( );

        int count = 0;

        for( int i = 0; i < arr.length ; i++ ){
            if ( arr[i] == 'a' ){
                count ++ ;
            }
