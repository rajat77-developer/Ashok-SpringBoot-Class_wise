package Class63;

import java.util.concurrent.Callable;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;

public class ThreadDemo {

	public static void main(String[] args) {

		Thread t1 = new Thread() {

			public void run() {

				System.out.println("run() method logic one ");

			}
		};
		t1.start();

		Runnable r = new Runnable() {

			@Override
			public void run() {

				System.out.println("this is run() method logic-2");
			}
		};
		
		Thread t2 = new Thread(r);
		t2.start();

		
		//Below is called anonymous approach to create thread 
		
		Callable c = new Callable() {

			@Override
			public Object call() throws Exception {

				System.out.println("call() method logic - 3");
				return null;
			}

		};

		ExecutorService exService = Executors.newFixedThreadPool(1);
		exService.submit(c);

	}
}



OUTPUT:
=======

run() method logic one 
this is run() method logic-2
call() method logic - 3


