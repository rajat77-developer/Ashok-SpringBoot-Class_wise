                One simple collection java program
---------------------------------------------------------------------------

package Collections;

import java.util.ArrayList;

public class CollectionsListDemo {
	
	
	public static void main(String[] args) {
		
	
		ArrayList al = new ArrayList();// object creation--> default capacity 10

		al.add(100);
		al.add(200);
		al.add("Raju");
		al.add("Ranu");
		al.add(1000.50);
		
		System.out.println("Size of array before removal :: "+al.size());
		al.remove(0);
		System.out.println("Size of array after removal::"+al.size());
		System.out.println(al);
	
	
	
	}
	
	
}



Output:
--------

Size of array before removal :: 5
Size of array after removal::4


























