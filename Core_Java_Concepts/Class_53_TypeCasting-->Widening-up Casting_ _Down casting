                                ==========================================
                                Typcasting with respect to Reference types
                                ==========================================


--> parent class object can be converted to child class.





package com.ibm.aadhar;

public class TypeCastingParentToChild implements Cloneable {
	
	public static void main(String[] args) throws Exception {
		
		
		//child object
		TypeCastingParentToChild d = new TypeCastingParentToChild();
		
		// storing child object into parent class reference variable
		Object obj = d;
		
		//cloning - getting parent object
		Object object = d.clone();
		
		//storing parent object into child class reference variable
		TypeCastingParentToChild d1 = (TypeCastingParentToChild)object;
		
	}

}















