			String s = null;
		    s.length();
		    
		    System.out.println("try block end....");
		
		} catch(Exception e) {
			System.out.println("in catch block..");
			e.printStackTrace();
			
		} 
		
		System.out.println("welcome to java......");
		
		System.out.println("main() method ended....... This is called graceful termination");
	}
}


