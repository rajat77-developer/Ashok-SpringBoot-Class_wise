package StreamAPIpkg;

import java.util.Arrays;
import java.util.List;
import java.util.stream.Stream;

public class FilterMethodExample1 {


		public static void main(String[] args) {
			
			User u1 = new User("john ", 25);
			User u2 = new User("johnee ", 26);
			User u3 = new User("joseph ", 27);
			User u4 = new User("joney ", 29);
			User u5 = new User("joke ", 23);
			User u6 = new User("josh ", 20);
			
			
			Stream<User> stream = Stream.of(u1, u2, u3, u4, u5, u6);
			
			stream.filter(i -> i.age >= 25 ).forEach(i -> System.out.println(i));
		}
}


class User{
	
	String name;
	int age;
	
	User(String name, int age){
		
		this.name=name;
		this.age=age;
